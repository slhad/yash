{
  "name": "yash",
  "version": "0.2.4",
  "module": "index.tsx",
  "type": "module",
  "private": true,
  "scripts": {
    "prestart": "bun run build:web",
    "start": "exec bun src/index.tsx",
    "prestart:tui": "bun run build:web",
    "start:tui": "YASH_TUI_ONLY=1 bun run src/index.tsx",
    "prestart:webui": "bun run build:web",
    "start:webui": "bun run src/index.ts",
    "validate:repo": "bun run scripts/validate-repo-artifacts.ts",
    "pretest": "bun run validate:repo && bun lint && bun typecheck",
    "test": "bun test",
    "test:coverage": "bun run scripts/check-coverage-threshold.ts",
    "test:e2e": "bun run src/index.ts &",
    "test:e2e:run": "playwright test",
    "build": "bun build --target=bun src/index.ts --outdir dist && mv dist/index.js dist/main.js",
    "build:web": "bun build --target=browser --format=esm --outfile src/utils/webCommands.bundle.js src/utils/webCommands.ts",
    "cmd": "bun run src/cli.ts",
    "lint": "biome check --write src test package.json biome.json",
    "typecheck": "bun --bun tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@playwright/test": "^1.59.1",
    "@types/bun": "latest",
    "playwright": "^1.59.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@nekiro/kick-api": "^2.1.2",
    "@opentui/core": "0.3.0",
    "@opentui/react": "0.3.0",
    "@twurple/api": "^8.1.3",
    "@twurple/auth": "^8.1.3",
    "@twurple/chat": "^8.1.3",
    "@twurple/eventsub-ws": "^8.1.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
