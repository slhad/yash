{
  "name": "yash",
  "module": "index.tsx",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts > /tmp/yash-web.log 2>&1 & YASH_WEB_PID=$! bun run src/index.tsx; kill $YASH_WEB_PID 2>/dev/null",
    "start:tui": "bun run src/index.tsx",
    "start:web": "bun run src/index.ts",

    "pretest": "bun lint",
    "test": "bun test",
    "test:e2e": "bun run src/index.ts &",
    "test:e2e:run": "playwright test",
    "lint": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@playwright/test": "^1.59.1",
    "@types/bun": "latest",
    "playwright": "^1.59.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@opentui/core": "^0.1.97",
    "@opentui/react": "^0.1.97",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
