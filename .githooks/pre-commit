#!/usr/bin/env bash
set -euo pipefail

echo "Running pre-commit secret scan..."

if command -v gitleaks >/dev/null 2>&1; then
  echo "gitleaks detected on PATH; running staged scan..."
  # Exit with non-zero if secrets found
  gitleaks detect --staged --exit-code 1 || {
    echo "gitleaks detected potential secrets in staged changes. Commit aborted." >&2
    exit 1
  }
else
  echo "gitleaks not found; falling back to bundled Node scanner"
  if command -v node >/dev/null 2>&1; then
    node scripts/precommit/fallback.js || exit 1
  elif command -v bun >/dev/null 2>&1; then
    bun run scripts/precommit/fallback.js || exit 1
  else
    echo "No runtime (node or bun) available to run fallback scanner; skipping secret scan." >&2
  fi
fi

exit 0
