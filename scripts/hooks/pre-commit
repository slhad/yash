#!/bin/sh
set -euo pipefail

# Simple pre-commit hook to detect likely plaintext secrets in staged files.
# Install by running `sh ./scripts/install-hooks.sh` or `bun run install-hooks`.

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM || true)
if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

echo "[pre-commit] scanning staged files for potential secrets..."
FOUND=0
for f in $STAGED_FILES; do
  case "$f" in
    node_modules/*|dist/*) continue ;;
    .git/*) continue ;;
  esac

  # If config.json is staged, always warn and block commit
  if [ "$f" = "config.json" ]; then
    echo "ERROR: You are attempting to commit config.json. Move secrets to config.json (gitignored) or use config.example.json as a template."
    FOUND=1
    continue
  fi

  # Use git show to examine the staged version of the file
  if git show :"$f" 2>/dev/null | grep -EnI "password|passwd|pwd|secret|api[_-]?key|token|access[_-]?key|client[_-]?secret" >/dev/null 2>&1; then
    echo "Potential secret match in staged file: $f"
    git --no-pager diff --cached -- "$f" | sed -n '1,200p'
    FOUND=1
  fi
done

if [ "$FOUND" -ne 0 ]; then
  echo "\nCommit aborted: potential plaintext secrets detected in staged files. Remove secrets, use config.example.json, and try again."
  exit 1
fi

exit 0
